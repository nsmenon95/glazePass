{
  "manifest_version": 3,
  "name": "glazePass",
  "version": "1.0.0",
  "description": "Offline cryptographically secure password generator.",
  "action": {
    "default_popup": "index.html",
    "default_title": "glazePass",
    "default_icon": "icon.svg"
  },
  "icons": {
    "16": "icon.svg",
    "32": "icon.svg",
    "48": "icon.svg",
    "128": "icon.svg"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "glazepass@nsmenon",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}